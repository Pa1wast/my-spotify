# Database (Neon PostgreSQL)
# Pooled connection for application runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Direct connection for Prisma migrations (Neon)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth0 (https://manage.auth0.com)
AUTH0_DOMAIN="your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your-client-id"
AUTH0_CLIENT_SECRET="your-client-secret"
AUTH0_SECRET="use-openssl-rand-hex-32-to-generate"
APP_BASE_URL="http://localhost:3000"

# Optional: override Auth0 session lifetime in seconds (fixed, non-rolling)
# Default: 604800 (7 days) in development, ~7776000 (~90 days) in production
# SESSION_ABSOLUTE_SECONDS="604800"

# Spotify Web API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID="your-spotify-client-id"
SPOTIFY_CLIENT_SECRET="your-spotify-client-secret"
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/spotify/callback"

# Vercel Cron — play history sync (set on Vercel; optional locally)
# CRON_SECRET="generate-with-openssl-rand-hex-32"
